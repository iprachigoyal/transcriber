# ---- LiveKit (get these from the Talksy operator) ----
# The same LiveKit server the host app uses.
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_chars_long

# ---- Agent identity / dispatch ----
# MUST match the name Talksy dispatches with (AgentDispatchClient.createDispatch).
AGENT_NAME=talksy-transcriber

# ---- Hugging Face Whisper Space ----
# Base URL of your deployed Space (no trailing slash needed).
HF_WHISPER_URL=https://your-user-your-space.hf.space
# Only needed if your Space is private.
HF_TOKEN=

# ---- Tuning (sane defaults; usually leave as-is) ----
SAMPLE_RATE=16000
VAD_SILENCE_MS=600
SEGMENT_MAX_MS=10000
SEGMENT_MIN_MS=300
# webrtcvad aggressiveness: 0 (least) .. 3 (most aggressive at filtering non-speech)
VAD_AGGRESSIVENESS=2
# Per-request HTTP timeout to the Space (seconds) for a warm Space.
HF_TIMEOUT_S=15
